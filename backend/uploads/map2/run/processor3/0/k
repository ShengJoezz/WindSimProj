FoamFile
{
    version     2.0;
    format      ascii;
    arch        "LSB;label=32;scalar=64";
    class       volScalarField;
    location    "0";
    object      k;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -2 0 0 0 0];

internalField   uniform 0.5;

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           nonuniform List<scalar> 0();
    }
    outlet
    {
        type            inletOutlet;
        inletValue      uniform 0.5;
        value           uniform 0.5;
    }
    front
    {
        type            symmetryPlane;
    }
    back
    {
        type            symmetryPlane;
    }
    bot
    {
        type            kqRWallFunction;
        value           uniform 0.5;
    }
    top
    {
        type            symmetryPlane;
    }
    procBoundary3to0
    {
        type            processor;
        value           uniform 0.5;
    }
    procBoundary3to1
    {
        type            processor;
        value           uniform 0.5;
    }
    procBoundary3to2
    {
        type            processor;
        value           uniform 0.5;
    }
}


