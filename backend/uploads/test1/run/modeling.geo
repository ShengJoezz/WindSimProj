Background Field = 24;
m = 6;
h0 = h1 / ceng;
V[] = Extrude{0, 0, h0} {
  Surface{m};
  Layers{1};
  Recombine;
};
m = m + 41;
For(2 : ceng)
  V[] = Extrude{0, 0, h0} {
    Surface{m};
    Layers{1};
    Recombine;
  };
  m = m + 22;
EndFor
h2 = h-h1;
N = Ceil(Log(h2 * (q1 - 1) / h0 / q1 + 1) / Log(q1)) - 1;
sum = 0;
For(1 : N)
  h0 = h0 * q1;
  s[] = Extrude{0, 0, h0} {
    Surface{m};
    Layers{1};
    Recombine;
  };
  m = m + 22;
  sum = h0 + sum;
EndFor
sumC = 6 + 41 + 22 * (ceng-1) + 22 * N;
Extrude Surface{sumC, {0, 0, h2 - sum}} {
  Recombine;
  Layers {1};
};
